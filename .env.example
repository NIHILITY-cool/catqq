# ============================================
# CatQQ Agent 环境变量
# 复制此文件为 .env 并填入你自己的信息
#   cp .env.example .env
# ============================================

# 联系人配置：QQ号|名字|关系，多个联系人用英文逗号分隔
# 白名单和身份识别都会从这里自动生成
CATQQ_CONTACTS=你的QQ号|主人|玖玖最重要的人

# 早安时间（24小时制）
CATQQ_MORNING_HOUR=8

# 晚安时间（24小时制）
CATQQ_NIGHT_HOUR=23

# 主动联系功能：目标可以填联系人名字，也可以填 QQ 号
CATQQ_PROACTIVE_ENABLED=true
CATQQ_PROACTIVE_TARGET=主人
CATQQ_PROACTIVE_ACTIVE_HOURS=10-23
CATQQ_PROACTIVE_MAX_PER_DAY=3
CATQQ_PROACTIVE_MIN_GAP_HOURS=3
CATQQ_PROACTIVE_INACTIVE_HOURS=6
CATQQ_PROACTIVE_AFTER_REPLY_COOLDOWN_MINUTES=60
CATQQ_PROACTIVE_RANDOM_CHANCE=0.08

# 旧配置仍兼容；新部署优先使用 CATQQ_CONTACTS
# CATQQ_ALLOWED_USERS=你的QQ号
# CATQQ_USER_IDENTITY=你的QQ号:主人
