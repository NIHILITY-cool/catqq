# ============================================
# CatQQ Agent 环境变量
# 复制此文件为 .env 并填入你自己的信息
#   cp .env.example .env
# ============================================

# 白名单 QQ 号，逗号分隔（只有这些号能给机器人发消息）
CATQQ_ALLOWED_USERS=你的QQ号

# 早安时间（24小时制）
CATQQ_MORNING_HOUR=8

# 晚安时间（24小时制）
CATQQ_NIGHT_HOUR=23

# 用户身份映射：QQ号:你想让AI叫他的名字,下一个QQ号:另一个名字
# 这样AI就知道在和谁说话，可以对不同人用不同态度
CATQQ_USER_IDENTITY=你的QQ号:主人
